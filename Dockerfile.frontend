FROM python:3.11-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir streamlit streamlit-extras requests pandas

COPY frontend/ ./frontend/

RUN useradd -m -u 1001 hrapp && chown -R hrapp:hrapp /app
USER hrapp

EXPOSE 8501

CMD streamlit run frontend/app.py --server.port=8501 --server.address=0.0.0.0 --server.headless=true
